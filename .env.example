DEBUG=True
PRODUCTION=False
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=
SECRET_KEY=replace-with-a-long-random-secret-before-production
# 本地 PyCharm 可使用 root 或单独创建的 MySQL 用户；不要提交真实密码。
DATABASE_URL=mysql://shoplite:change-me@127.0.0.1:3306/shoplite
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=shoplite
MYSQL_USER=shoplite
MYSQL_PASSWORD=replace-with-database-password
MYSQL_ROOT_PASSWORD=replace-with-different-root-password
REDIS_URL=redis://127.0.0.1:6379/0
USE_REDIS_CACHE=False
TRUST_PROXY_HEADERS=False
SECURE_SSL_REDIRECT=True
SHOPLITE_PAYMENT_SECRET=
ENABLE_MOCK_PAYMENT=True

# console: print verification codes in the Django console.
# tencent: send real SMS through Tencent Cloud SMS.
SMS_PROVIDER=console
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_REGION=ap-guangzhou

# disabled: show "not available" (safe default).
# mock: local development only; never enable it in production.
# allauth: redirect to django-allauth's real WeChat OAuth flow.
WECHAT_LOGIN_MODE=disabled
WECHAT_APP_ID=
WECHAT_APP_SECRET=
